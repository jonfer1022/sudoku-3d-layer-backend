# Backend environment variables (keys only).
# Do not commit real secrets. Configure values in your hosting platform.

# Server
PORT=3000
TRUST_PROXY=false

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# JWT
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# Google OAuth (backend-hosted flow)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# Allowed redirect destinations for the backend-hosted Google OAuth flow.
# Format: comma-separated entries:
# - scheme:<schemeName> (e.g. scheme:sudoku3dlayer)
# - https:<host> (e.g. https:app.example.com)
GOOGLE_OAUTH_ALLOWED_REDIRECTS="scheme:sudoku3dlayer,https:localhost:8081"

# For Expo Go development (optional), you may need to allow these schemes too:
GOOGLE_OAUTH_ALLOWED_REDIRECTS="scheme:sudoku3dlayer,scheme:exp,scheme:exps"

# Frontend URL (used as fallback redirect for Google OAuth)
FRONTEND_URL="http://localhost:8081"

# CORS (web only; native apps usually send no Origin header)
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:8081,http://localhost:19006"

# Rate limiting
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=120
AUTH_RATE_LIMIT_TTL_SECONDS=60
AUTH_RATE_LIMIT_LIMIT=20

# AWS Cognito
AWS_COGNITO_REGION="us-east-1"
AWS_COGNITO_USER_POOL_ID=""
AWS_COGNITO_CLIENT_ID=""

# Optional: only if you enable a Cognito App Client secret.
# AWS_COGNITO_CLIENT_SECRET=""

# AWS credentials
# If deploying on AWS with an IAM role, you can omit these.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
